# Copy these into Vercel dashboard → Project → Settings → Environment Variables

# From Neon dashboard → Connection Details → Connection string (psycopg2 format)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/freshline?sslmode=require

# Change this to any long random string for production
JWT_SECRET=change-me-to-a-long-random-string-in-production
